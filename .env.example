# Cloudflare Access credentials
#
# For local dev (pnpm dev):  copy to .env.local
# For Docker build:          copy to .env  (docker compose reads this automatically)
#
VITE_CF_ACCESS_CLIENT_ID=your-cf-access-client-id
VITE_CF_ACCESS_CLIENT_SECRET=your-cf-access-client-secret

# WebSocket static token (optional)
# If set, WebSocket uses this static token instead of JWT access token.
# Configure the same value in freqtrade config.json: "api_server": { "ws_token": "..." }
# This avoids WebSocket reconnection on JWT token refresh.
VITE_WS_TOKEN=
